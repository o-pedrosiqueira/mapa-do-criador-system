{
  "permissions": {
    "allow": [
      "Write(meus-produtos/**)",
      "Read(.claude/commands/**)",
      "Read(.claude/agents/**)",
      "Read(.claude/skills/**)",
      "Read(.claude/hooks/**)",
      "Read(.cursor/rules/**)",
      "Read(.github/**)",
      "Read(assets/**)",
      "Read(painel/**)",
      "Read(scripts/**)",
      "Read(meus-produtos/**)",
      "Read(AGENTS.md)",
      "Read(ARQUITETURA.md)",
      "Read(CLAUDE.md)",
      "Read(COMO-USAR.md)",
      "Read(README.md)",
      "Read(.env.example)",
      "Read(package.json)",
      "Read(vercel.json)",
      "WebFetch(*)",
      "WebSearch(*)",
      "Bash(ls *)",
      "Bash(vercel *)",
      "Bash(python3)"
    ]
  },
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/setup-node.sh"
          }
        ]
      },
      {
        "hooks": [
          {
            "type": "command",
            "command": "node .claude/hooks/gsd-check-update.js"
          }
        ]
      },
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/gsd-session-state.sh"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Bash|Edit|Write|MultiEdit|Agent|Task",
        "hooks": [
          {
            "type": "command",
            "command": "node .claude/hooks/gsd-context-monitor.js",
            "timeout": 10
          }
        ]
      },
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/gsd-phase-boundary.sh",
            "timeout": 5
          }
        ]
      },
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "node .claude/hooks/copy-review.js",
            "timeout": 5
          }
        ]
      },
      {
        "matcher": "Write|Edit|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "node .claude/hooks/painel-validar.js",
            "timeout": 5
          }
        ]
      },
      {
        "matcher": "Write|Edit|Bash|Agent|Task|WebFetch|WebSearch",
        "hooks": [
          {
            "type": "command",
            "command": "node .claude/hooks/agent-status-writer.js",
            "timeout": 5
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "node .claude/hooks/no-emdash-guard.js",
            "timeout": 5
          }
        ]
      },
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "node .claude/hooks/gsd-prompt-guard.js",
            "timeout": 5
          }
        ]
      },
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "node .claude/hooks/gsd-read-guard.js",
            "timeout": 5
          }
        ]
      },
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "node .claude/hooks/gsd-workflow-guard.js",
            "timeout": 5
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/gsd-validate-commit.sh",
            "timeout": 5
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "node .claude/hooks/gsd-statusline.js"
  }
}
